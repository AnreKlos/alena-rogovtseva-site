---
interface Props {
  service: {
    slug: string;
    name: string;
    price: string;
    description: string;
    category: string;
    image: string;
  };
}

const { service } = Astro.props;
---

<article class="service-card" data-service-card data-slug={service.slug} data-name={service.name} data-price={service.price} data-description={service.description} data-image={service.image}>
  <div class="service-card-image">
    <img
      src={service.image}
      alt={service.name}
      loading="lazy"
      onerror="this.style.display='none'"
    />
  </div>
  <div class="service-card-info">
    <h3>{service.name}</h3>
    <p>{service.description}</p>
  </div>
  <div class="service-card-footer">
    <span class="service-price">{service.price}</span>
    <span class="btn-small">Записаться</span>
  </div>
</article>

<style>
  .service-card {
    background: var(--color-surface);
    padding: 18px 18px 24px;
    box-shadow: var(--shadow-soft);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-accent-soft) 0%, transparent 50%);
    pointer-events: none;
  }

  .service-card:hover {
    transform: translateY(-6px) rotate(0.5deg);
    box-shadow: var(--shadow-strong);
  }

  .service-card-image {
    height: 240px;
    overflow: hidden;
    background: var(--color-surface-2);
    margin-bottom: 16px;
  }

  .service-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.6s ease;
  }

  .service-card:hover .service-card-image img {
    transform: scale(1.03);
  }

  .service-card-info h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-main);
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  .service-card-info p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    font-weight: 300;
  }

  .service-card-footer {
    padding: 16px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-border-subtle);
    margin-top: 16px;
  }

  .service-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: -0.02em;
  }

  .btn-small {
    padding: 8px 20px;
    background: transparent;
    color: var(--color-text-main);
    border: 1.5px solid var(--color-text-main);
    border-radius: 0;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-small:hover {
    background: var(--color-text-main);
    color: var(--color-on-accent);
  }
</style>
