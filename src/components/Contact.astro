---
---
<section class="contact-section" id="contact">
  <div class="container">
    <h2 class="section-title">Запись на услугу</h2>
    <p class="section-subtitle">Оставьте заявку, и мы свяжемся с вами для подтверждения</p>

    <div class="contact-grid">
      <div class="contact-form">
        <form>
          <div class="form-field">
            <label for="name">Имя</label>
            <input type="text" id="name" name="name" placeholder="Ваше имя" />
          </div>
          <div class="form-field">
            <label for="phone">Телефон</label>
            <input type="tel" id="phone" name="phone" placeholder="+7 (___) ___-__-__" />
          </div>
          <div class="form-field">
            <label for="service">Услуга</label>
            <select id="service" name="service">
              <option value="">Выберите услугу</option>
              <option value="lashes">Ресницы</option>
              <option value="nails">Ногтевой сервис</option>
              <option value="brows">Брови и макияж</option>
              <option value="training">Обучение</option>
            </select>
          </div>
          <div class="form-field">
            <label for="message">Комментарий</label>
            <textarea id="message" name="message" rows="4" placeholder="Пожелания к записи..."></textarea>
          </div>
          <button type="submit" class="contact-submit">Отправить заявку</button>
        </form>
      </div>

      <div class="contact-info">
        <div class="contact-item">
          <span class="contact-label">Адрес</span>
          <span class="contact-value">Брянск, Московский проспект, 49А</span>
          <span class="contact-hint">Справа от ТЦ «Европа», вход слева между офисными зданиями</span>
        </div>
        <div class="contact-item">
          <span class="contact-label">Телефон</span>
          <a class="contact-value contact-phone" href="tel:+796****3119">+7 (961) 104-31-19</a>
        </div>
        <div class="contact-item">
          <span class="contact-label">Режим работы</span>
          <span class="contact-value">Ежедневно с 8:30 до 21:00</span>
        </div>
        <div class="contact-item">
          <span class="contact-label">Соцсети</span>
          <a class="contact-value contact-social" href="#" target="_blank" rel="noopener">ВКонтакте</a>
        </div>
      </div>
    </div>

    <div class="contact-map">
      <div id="yandex-map" style="width: 100%; height: 400px;"></div>
    </div>

    <script src="https://api-maps.yandex.ru/2.1/?lang=ru_RU" is:inline></script>
    <script is:inline>
      ymaps.ready(init);
      function init() {
        var myMap = new ymaps.Map("yandex-map", {
          center: [53.215127, 34.421717],
          zoom: 16,
          controls: ['zoomControl']
        });
        var myPlacemark = new ymaps.Placemark([53.215127, 34.421717], {}, {});
        myMap.geoObjects.add(myPlacemark);
      }
    </script>
  </div>
</section>

<style>
  .contact-section {
    padding: 80px 0;
    background: var(--color-surface);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 48px;
  }

  .form-field {
    margin-bottom: 20px;
  }

  .form-field label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-main);
    margin-bottom: 6px;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--color-border-subtle);
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--color-text-main);
    background: var(--color-surface);
    box-sizing: border-box;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--color-text-muted);
  }

  .contact-submit {
    display: inline-block;
    padding: 14px 36px;
    background: var(--color-accent);
    color: var(--color-on-accent);
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .contact-submit:hover {
    background: var(--color-accent-hover);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .contact-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-value {
    font-size: 1rem;
    color: var(--color-text-main);
  }

  .contact-hint {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .contact-phone {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .contact-phone:hover {
    text-decoration: underline;
  }

  .contact-social {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .contact-social:hover {
    text-decoration: underline;
  }

  .contact-map {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }

  .contact-map > div {
    display: block;
    width: 100%;
    height: 400px;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .contact-section {
      padding: 50px 0;
    }

    .contact-map {
      border-radius: 12px;
    }

    .contact-map > div {
      height: 300px;
    }
  }
</style>
