---

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-title">Студия красоты<br />Алёны Роговцевой</h1>
    <p class="hero-subtitle">Наращивание ресниц, маникюр, педикюр, брови и макияж — с заботой о деталях</p>
    <a href="#contact" class="hero-cta">Записаться</a>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #faf7f2 0%, #f0e8de 100%);
    padding: 2rem 1rem;
  }

  .hero-inner {
    max-width: 800px;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #2d2018;
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: #6b5a4e;
    max-width: 560px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: inline-block;
    padding: 0.875rem 2.5rem;
    background: #b08968;
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 9999px;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .hero-cta:hover {
    background: #9a7555;
    transform: translateY(-1px);
  }

  .hero-cta:active {
    transform: translateY(0);
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 80vh;
      padding: 1.5rem 1rem;
    }

    .hero-cta {
      display: block;
      text-align: center;
    }
  }
</style>
