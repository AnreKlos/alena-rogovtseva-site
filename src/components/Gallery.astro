<script>
  const tabs = document.querySelectorAll('.gallery-tab');
  const items = document.querySelectorAll('.gallery-item');
  const loadMoreBtn = document.querySelector('.gallery-load-more');
  const ITEMS_PER_LOAD = 8;
  let currentFilter = 'all';
  let visibleCount = ITEMS_PER_LOAD;

  function getFilteredItems() {
    return Array.from(items).filter(item => {
      return currentFilter === 'all' || item.dataset.category === currentFilter;
    });
  }

  function updateVisibility() {
    const filtered = getFilteredItems();
    visibleCount = Math.min(visibleCount, filtered.length);
    
    // Hide all first
    items.forEach(item => item.style.display = 'none');
    
    // Show first visibleCount of filtered
    filtered.slice(0, visibleCount).forEach(item => {
      item.style.display = '';
    });
    
    // Toggle button
    if (visibleCount >= filtered.length) {
      loadMoreBtn.style.display = 'none';
    } else {
      loadMoreBtn.style.display = 'inline-block';
    }
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentFilter = tab.dataset.filter;
      visibleCount = ITEMS_PER_LOAD;
      updateVisibility();
    });
  });

  loadMoreBtn.addEventListener('click', () => {
    visibleCount += ITEMS_PER_LOAD;
    updateVisibility();
  });

  // Initial state
  updateVisibility();
</script>

<style>
  .gallery-section {
    padding: 80px 0;
    background: var(--color-surface);
  }

  .gallery-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 32px;
  }

  .gallery-tab {
    padding: 10px 20px;
    border: 1px solid var(--color-border-subtle);
    background: transparent;
    border-radius: 24px;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--color-text-main);
    transition: all 0.2s ease;
  }

  .gallery-tab:hover {
    background: var(--color-surface-2);
    border-color: var(--color-border-subtle);
  }

  .gallery-tab.active {
    background: var(--color-accent);
    color: var(--color-on-accent);
    border-color: var(--color-accent);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .gallery-item {
    aspect-ratio: 3 / 4;
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-surface-2);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-load-more {
    display: block;
    margin: 32px auto 0;
    padding: 12px 32px;
    border: 1px solid var(--color-accent);
    background: transparent;
    color: var(--color-accent);
    border-radius: 24px;
    cursor: pointer;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .gallery-load-more:hover {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }

  @media (max-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .gallery-tabs {
      gap: 8px;
      margin-bottom: 24px;
    }

    .gallery-tab {
      padding: 8px 16px;
      font-size: 0.85rem;
    }

    .gallery-section {
      padding: 50px 0;
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }
  }
</style>
