          <img src="/assets/img/gallery/works/lashes/lashes3.webp" alt="Ресницы 3" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="lashes" data-index="3">
          <img src="/assets/img/gallery/works/lashes/lashes4.webp" alt="Ресницы 4" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="lashes" data-index="4">
          <img src="/assets/img/gallery/works/lashes/lashes5.webp" alt="Ресницы 5" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="lashes" data-index="5">
          <img src="/assets/img/gallery/works/lashes/lashes6.webp" alt="Ресницы 6" loading="lazy" />
