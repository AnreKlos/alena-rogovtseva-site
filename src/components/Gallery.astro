<!-- Lightbox -->
<div class="gallery-lightbox" id="gallery-lightbox" hidden>
  <div class="gallery-lightbox-backdrop"></div>
  <button class="gallery-lightbox-close" aria-label="Закрыть">&times;</button>
  <button class="gallery-lightbox-nav gallery-lightbox-prev" aria-label="Назад">&#8249;</button>
  <button class="gallery-lightbox-nav gallery-lightbox-next" aria-label="Вперёд">&#8250;</button>
  <div class="gallery-lightbox-img-wrap">
    <img class="gallery-lightbox-img" src="" alt="" />
  </div>
</div>

<script>
  const allItems = document.querySelectorAll('.gallery-item');
  const grid = document.getElementById('gallery-grid');
  const tabs = document.querySelectorAll('.gallery-tab');
  const loadMoreBtn = document.querySelector('.gallery-load-more');

  const ITEMS_PER_LOAD = 6;
  let currentFilter = 'all';
  let visibleCount = ITEMS_PER_LOAD;

  function getFilteredItems() {
    return Array.from(allItems).filter(item => {
      return currentFilter === 'all' || item.dataset.category === currentFilter;
    });
  }

  function updateVisibility() {
    const filtered = getFilteredItems();
    visibleCount = Math.min(visibleCount, filtered.length);

    allItems.forEach(item => item.style.display = 'none');
    filtered.slice(0, visibleCount).forEach(item => {
      item.style.display = '';
    });

    if (visibleCount >= filtered.length) {
      loadMoreBtn.style.display = 'none';
    } else {
      loadMoreBtn.style.display = 'inline-block';
    }
  }

  // Tab click
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentFilter = tab.dataset.filter;
      visibleCount = ITEMS_PER_LOAD;
      updateVisibility();
      closeLightbox();
    });
  });

  // Load more
  loadMoreBtn.addEventListener('click', () => {
    visibleCount += ITEMS_PER_LOAD;
    updateVisibility();
  });

  // Grid item click → open lightbox
  allItems.forEach(item => {
    item.addEventListener('click', () => {
      const filtered = getFilteredItems();
      const visible = filtered.slice(0, visibleCount);
      const idx = visible.indexOf(item);
      if (idx !== -1) openLightbox(idx);
    });
  });

  // ---- Lightbox ----
  const lightbox = document.getElementById('gallery-lightbox');
  const lightboxImg = lightbox.querySelector('.gallery-lightbox-img');
  const lightboxClose = lightbox.querySelector('.gallery-lightbox-close');
  const lightboxPrev = lightbox.querySelector('.gallery-lightbox-prev');
  const lightboxNext = lightbox.querySelector('.gallery-lightbox-next');
  const lightboxBackdrop = lightbox.querySelector('.gallery-lightbox-backdrop');

  let currentLightboxIndex = -1;

  function openLightbox(index) {
    const filtered = getFilteredItems();
    const visible = filtered.slice(0, visibleCount);
    if (!visible.length) return;
    currentLightboxIndex = index;
    const item = visible[currentLightboxIndex];
    const img = item.querySelector('img');
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  function navLightbox(direction) {
    const filtered = getFilteredItems();
    const visible = filtered.slice(0, visibleCount);
    if (!visible.length) return;
    currentLightboxIndex = (currentLightboxIndex + direction + visible.length) % visible.length;
    const item = visible[currentLightboxIndex];
    const img = item.querySelector('img');
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;
  }

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBackdrop.addEventListener('click', closeLightbox);
  lightboxPrev.addEventListener('click', () => navLightbox(-1));
  lightboxNext.addEventListener('click', () => navLightbox(1));

  document.addEventListener('keydown', (e) => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navLightbox(-1);
    if (e.key === 'ArrowRight') navLightbox(1);
  });

  // Initial state
  updateVisibility();
</script>

<style>
  .gallery-section {
    padding: 80px 0;
    background: var(--color-surface);
  }

  .gallery-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
  }

  .gallery-tab {
    padding: 10px 20px;
    border: 1px solid var(--color-border-subtle);
    background: transparent;
    border-radius: 24px;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--color-text-main);
    transition: all 0.2s ease;
  }

  .gallery-tab:hover {
    background: var(--color-surface-2);
    border-color: var(--color-border-subtle);
  }

  .gallery-tab.active {
    background: var(--color-accent);
    color: var(--color-on-accent);
    border-color: var(--color-accent);
  }

  /* ---- Luxury Contact Sheet ---- */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 3 / 4;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface-2);
    transition: box-shadow 0.4s ease, transform 0.4s ease;
    will-change: transform;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery-item:hover {
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
    transform: translateY(-2px);
  }

  .gallery-item:hover img {
    transform: scale(1.04);
  }

  .gallery-load-more {
    display: block;
    margin: 40px auto 0;
    padding: 12px 32px;
    border: 1px solid var(--color-accent);
    background: transparent;
    color: var(--color-accent);
    border-radius: 24px;
    cursor: pointer;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .gallery-load-more:hover {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }

  /* ---- Lightbox ---- */
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    cursor: pointer;
  }

  .gallery-lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 2001;
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    color: #fff;
    font-size: 36px;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-lightbox-close:hover {
    opacity: 1;
  }

  .gallery-lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2001;
    width: 48px;
    height: 48px;
    border: none;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-size: 32px;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    line-height: 1;
    opacity: 0.8;
  }

  .gallery-lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.18);
    opacity: 1;
  }

  .gallery-lightbox-prev {
    left: 20px;
  }

  .gallery-lightbox-next {
    right: 20px;
  }

  .gallery-lightbox-img-wrap {
    position: relative;
    z-index: 2000;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    display: block;
  }

  @media (max-width: 1024px) {
    .gallery-grid {
      gap: 14px;
    }
  }

  @media (max-width: 768px) {
    .gallery-section {
      padding: 50px 0;
    }

    .gallery-tabs {
      gap: 8px;
      margin-bottom: 28px;
    }

    .gallery-tab {
      padding: 8px 16px;
      font-size: 0.85rem;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .gallery-item {
      aspect-ratio: 3 / 4;
    }

    .gallery-lightbox-prev {
      left: 12px;
    }

    .gallery-lightbox-next {
      right: 12px;
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      gap: 10px;
    }

    .gallery-lightbox-close {
      top: 12px;
      right: 16px;
    }
  }
</style>
