        </div>
        <div class="gallery-thumb" data-category="manicure" data-index="3">
          <img src="/assets/img/gallery/works/manicure/manicure4.webp" alt="Маникюр 4" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="manicure" data-index="4">
          <img src="/assets/img/gallery/works/manicure/manicure5.webp" alt="Маникюр 5" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="manicure" data-index="5">
          <img src="/assets/img/gallery/works/manicure/manicure6.webp" alt="Маникюр 6" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="manicure" data-index="6">
