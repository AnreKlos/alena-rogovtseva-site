        <div class="gallery-thumb" data-category="lashes" data-index="7">
          <img src="/assets/img/gallery/works/lashes/lashes8.webp" alt="Ресницы 8" loading="lazy" />
        </div>

        <!-- Brows -->
        <div class="gallery-thumb" data-category="brows" data-index="0">
          <img src="/assets/img/gallery/works/brows/brows1.webp" alt="Брови 1" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="brows" data-index="1">
          <img src="/assets/img/gallery/works/brows/brows2.webp" alt="Брови 2" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="brows" data-index="2">
          <img src="/assets/img/gallery/works/brows/brows3.webp" alt="Брови 3" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="brows" data-index="3">
          <img src="/assets/img/gallery/works/brows/brows4.webp" alt="Брови 4" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="brows" data-index="4">
          <img src="/assets/img/gallery/works/brows/brows5.webp" alt="Брови 5" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="brows" data-index="5">
          <img src="/assets/img/gallery/works/brows/brows6.webp" alt="Брови 6" loading="lazy" />
        </div>

        <!-- Manicure -->
        <div class="gallery-thumb" data-category="manicure" data-index="0">
