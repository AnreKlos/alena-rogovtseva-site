        </div>
        <div class="gallery-thumb" data-category="pedicure" data-index="1">
          <img src="/assets/img/gallery/works/pedicure/pedicure2.webp" alt="Педикюр 2" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="pedicure" data-index="2">
          <img src="/assets/img/gallery/works/pedicure/pedicure3.webp" alt="Педикюр 3" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="pedicure" data-index="3">
          <img src="/assets/img/gallery/works/pedicure/pedicure4.webp" alt="Педикюр 4" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="pedicure" data-index="4">
          <img src="/assets/img/gallery/works/pedicure/pedicure5.webp" alt="Педикюр 5" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="pedicure" data-index="5">
          <img src="/assets/img/gallery/works/pedicure/pedicure6.webp" alt="Педикюр 6" loading="lazy" />
        </div>
        <div class="gallery-thumb" data-category="pedicure" data-index="6">
          <img src="/assets/img/gallery/works/pedicure/pedicure7.webp" alt="Педикюр 7" loading="lazy" />
        </div>
      </div>
    </div>

    <button class="gallery-load-more">Показать ещё</button>
  </div>
</section>

<!-- Lightbox -->
<div class="gallery-lightbox" id="gallery-lightbox" hidden>
  <div class="gallery-lightbox-backdrop"></div>
  <button class="gallery-lightbox-close" aria-label="Закрыть">&times;</button>
  <button class="gallery-lightbox-nav gallery-lightbox-prev" aria-label="Назад">&#8249;</button>
  <button class="gallery-lightbox-nav gallery-lightbox-next" aria-label="Вперёд">&#8250;</button>
  <div class="gallery-lightbox-img-wrap">
    <img class="gallery-lightbox-img" src="" alt="" />
  </div>
</div>

<script>
  const tabs = document.querySelectorAll('.gallery-tab');
  const allThumbs = document.querySelectorAll('.gallery-thumb');
  const featuredImg = document.getElementById('gallery-featured-img');
  const featuredWrap = document.getElementById('gallery-featured');
  const thumbnails = document.getElementById('gallery-thumbnails');
  const loadMoreBtn = document.querySelector('.gallery-load-more');

  const ITEMS_PER_LOAD = 6;
  let currentFilter = 'all';
  let visibleCount = ITEMS_PER_LOAD;
  let currentActiveIndex = 0;
  let activeCategoryThumbs = [];

  function getFilteredThumbs() {
    return Array.from(allThumbs).filter(t => {
      return currentFilter === 'all' || t.dataset.category === currentFilter;
    });
  }

  function getVisibleThumbs() {
    return activeCategoryThumbs.slice(0, visibleCount);
  }

  function setFeatured(thumb) {
    const img = thumb.querySelector('img');
    featuredImg.src = img.src;
    featuredImg.alt = img.alt;
    // Update active state on thumbs
    getVisibleThumbs().forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
    currentActiveIndex = Array.from(allThumbs).indexOf(thumb);
  }

  function updateVisibility() {
    activeCategoryThumbs = getFilteredThumbs();
    visibleCount = Math.min(visibleCount, activeCategoryThumbs.length);

    // Hide all thumbs
    allThumbs.forEach(t => t.style.display = 'none');

    // Show visible thumbs
    const visible = activeCategoryThumbs.slice(0, visibleCount);
    visible.forEach((t, i) => {
      t.style.display = '';
      t.dataset.index = i;
    });

    // Set first visible as featured if current is not visible
    const currentThumb = allThumbs[currentActiveIndex];
    if (!currentThumb || currentThumb.style.display === 'none') {
      if (visible.length > 0) {
        setFeatured(visible[0]);
      }
    } else {
      // Re-apply active class in case visibility changed
      getVisibleThumbs().forEach(t => {
        if (t === currentThumb) {
          t.classList.add('active');
          // Re-set featured src in case it was cleared
          const img = t.querySelector('img');
          featuredImg.src = img.src;
          featuredImg.alt = img.alt;
        } else {
          t.classList.remove('active');
        }
      });
    }

    // Toggle button
    if (visibleCount >= activeCategoryThumbs.length) {
      loadMoreBtn.style.display = 'none';
    } else {
      loadMoreBtn.style.display = 'inline-block';
    }
  }

  // Tab click
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentFilter = tab.dataset.filter;
      visibleCount = ITEMS_PER_LOAD;
      updateVisibility();
      closeLightbox();
    });
  });

  // Load more
  loadMoreBtn.addEventListener('click', () => {
    visibleCount += ITEMS_PER_LOAD;
    updateVisibility();
  });

  // Thumbnail click → set featured
  allThumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      if (thumb.style.display === 'none') return;
      setFeatured(thumb);
      // Scroll featured into view smoothly on mobile
      featuredWrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });

  // Featured image click → open lightbox
  featuredWrap.addEventListener('click', () => {
    const activeThumb = getVisibleThumbs().find(t => t.classList.contains('active'));
    if (!activeThumb) return;
    const visible = getVisibleThumbs();
    const idx = visible.indexOf(activeThumb);
    if (idx !== -1) openLightbox(idx);
  });

  // ---- Lightbox ----
  const lightbox = document.getElementById('gallery-lightbox');
  const lightboxImg = lightbox.querySelector('.gallery-lightbox-img');
  const lightboxClose = lightbox.querySelector('.gallery-lightbox-close');
  const lightboxPrev = lightbox.querySelector('.gallery-lightbox-prev');
  const lightboxNext = lightbox.querySelector('.gallery-lightbox-next');
  const lightboxBackdrop = lightbox.querySelector('.gallery-lightbox-backdrop');

  let currentLightboxIndex = -1;

  function openLightbox(index) {
    const visible = getVisibleThumbs();
    if (!visible.length) return;
    currentLightboxIndex = index;
    const thumb = visible[currentLightboxIndex];
    const img = thumb.querySelector('img');
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  function navLightbox(direction) {
    const visible = getVisibleThumbs();
    if (!visible.length) return;
    currentLightboxIndex = (currentLightboxIndex + direction + visible.length) % visible.length;
    const thumb = visible[currentLightboxIndex];
    const img = thumb.querySelector('img');
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;
  }

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBackdrop.addEventListener('click', closeLightbox);
  lightboxPrev.addEventListener('click', () => navLightbox(-1));
  lightboxNext.addEventListener('click', () => navLightbox(1));

  document.addEventListener('keydown', (e) => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navLightbox(-1);
    if (e.key === 'ArrowRight') navLightbox(1);
  });

  // Initial state
  updateVisibility();
</script>

<style>
  .gallery-section {
    padding: 80px 0;
    background: var(--color-surface);
  }

  .gallery-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
  }

  .gallery-tab {
    padding: 10px 20px;
    border: 1px solid var(--color-border-subtle);
    background: transparent;
    border-radius: 24px;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--color-text-main);
    transition: all 0.2s ease;
  }

  .gallery-tab:hover {
    background: var(--color-surface-2);
    border-color: var(--color-border-subtle);
  }

  .gallery-tab.active {
    background: var(--color-accent);
    color: var(--color-on-accent);
    border-color: var(--color-accent);
  }

  /* ---- Filmstrip Layout ---- */
  .gallery-filmstrip {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Featured Image */
  .gallery-featured {
    position: relative;
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface-2);
  }

  .gallery-featured img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    transition: opacity 0.35s ease;
  }

  /* Thumbnail Rail */
  .gallery-thumbnails {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border-subtle) transparent;
  }

  .gallery-thumbnails::-webkit-scrollbar {
    height: 4px;
  }
  .gallery-thumbnails::-webkit-scrollbar-track {
    background: transparent;
  }
  .gallery-thumbnails::-webkit-scrollbar-thumb {
    background: var(--color-border-subtle);
    border-radius: 4px;
  }

  .gallery-thumb {
    flex: 0 0 auto;
    width: 120px;
    aspect-ratio: 3 / 4;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    scroll-snap-align: start;
    border: 2px solid transparent;
    transition: border-color 0.25s ease, opacity 0.25s ease;
    opacity: 0.65;
    background: var(--color-surface-2);
  }

  .gallery-thumb:hover {
    opacity: 0.85;
  }

  .gallery-thumb.active {
    border-color: var(--color-accent);
    opacity: 1;
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-load-more {
    display: block;
    margin: 40px auto 0;
    padding: 12px 32px;
    border: 1px solid var(--color-accent);
    background: transparent;
    color: var(--color-accent);
    border-radius: 24px;
    cursor: pointer;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .gallery-load-more:hover {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }

  /* ---- Lightbox ---- */
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    cursor: pointer;
  }

  .gallery-lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 2001;
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    color: #fff;
    font-size: 36px;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-lightbox-close:hover {
    opacity: 1;
  }

  .gallery-lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2001;
    width: 48px;
    height: 48px;
    border: none;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    font-size: 32px;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    line-height: 1;
    opacity: 0.8;
  }

  .gallery-lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.18);
    opacity: 1;
  }

  .gallery-lightbox-prev {
    left: 20px;
  }

  .gallery-lightbox-next {
    right: 20px;
  }

  .gallery-lightbox-img-wrap {
    position: relative;
    z-index: 2000;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gallery-lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    display: block;
  }

  @media (max-width: 1024px) {
    .gallery-thumb {
      width: 100px;
    }
  }

  @media (max-width: 768px) {
    .gallery-section {
      padding: 50px 0;
    }

    .gallery-tabs {
      gap: 8px;
      margin-bottom: 28px;
    }

    .gallery-tab {
      padding: 8px 16px;
      font-size: 0.85rem;
    }

    .gallery-filmstrip {
      gap: 16px;
    }

    .gallery-featured {
      border-radius: 16px;
    }

    .gallery-thumb {
      width: 85px;
      border-radius: 10px;
    }

    .gallery-thumbnails {
      gap: 10px;
    }

    .gallery-lightbox-prev {
      left: 12px;
    }

    .gallery-lightbox-next {
      right: 12px;
    }
  }

  @media (max-width: 480px) {
    .gallery-thumb {
      width: 72px;
    }

    .gallery-thumbnails {
      gap: 8px;
    }

    .gallery-lightbox-close {
      top: 12px;
      right: 16px;
    }
  }
</style>
