---
---
<section id="about" class="about-section">
  <div class="about-layout">
    <div class="about-media">
      <div class="about-carousel" id="aboutCarousel">
        <div class="about-track">
          <img
            src="/assets/img/about/rogovtseva1.webp"
            alt="Алёна Роговцева в студии"
            class="about-slide"
            loading="lazy"
          />
          <img
            src="/assets/img/about/rogovtseva2.jpg"
            alt="Алёна Роговцева"
            class="about-slide"
            loading="lazy"
          />
          <img
            src="/assets/img/about/rogovtseva3.webp"
            alt="Работа в студии"
            class="about-slide"
            loading="lazy"
          />
        </div>
      </div>
    </div>
    <div class="about-content">
      <h2 class="about-title">Немного обо мне</h2>
      <p class="about-text">
        Я в бьюти уже больше 10 лет и до сих пор люблю сложные случаи — будь то «непростые» брови, проблемная кожа или большие объёмы ресниц. Мне важно не просто сделать красиво, а чтобы вы реально нравились себе в зеркало и чувствовали себя комфортно.
      </p>
      <p class="about-text">
        Я много учусь сама и делюсь опытом с ученицами — разбираем ошибки, дорабатываем технику, чтобы каждая работа была честной и аккуратной.
      </p>
      <div class="about-stats">
        <div class="about-stat">
          <span class="about-stat-number" data-count="10">0</span>
          <span class="about-stat-label">лет опыта</span>
        </div>
        <div class="about-stat">
          <span class="about-stat-number" data-count="269">0</span>
          <span class="about-stat-label">довольных клиентов</span>
        </div>
        <div class="about-stat">
          <span class="about-stat-number" data-count="5000">0</span>
          <span class="about-stat-label">процедур</span>
        </div>
        <div class="about-stat">
          <span class="about-stat-number" data-count="5">0</span>
          <span class="about-stat-label">★ рейтинг</span>
        </div>
        <a href="#contact" class="about-cta">Записаться на визит</a>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.about-slide');
  let current = 0;
  slides[current].classList.add('active');
  setInterval(() => {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
  }, 5000);

  const counters = document.querySelectorAll('.about-stat-number');
  const animateCount = (el) => {
    const target = parseInt(el.getAttribute('data-count'), 10);
    const duration = 2000;
    const start = performance.now();
    const step = (now) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const current = Math.floor(progress * target);
      el.textContent = current.toLocaleString('ru-RU');
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = target.toLocaleString('ru-RU');
      }
    };
    requestAnimationFrame(step);
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        counters.forEach((c) => animateCount(c));
        observer.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const statsBlock = document.querySelector('.about-stats');
  if (statsBlock) observer.observe(statsBlock);
</script>

<style>
  .about-section {
    padding: 60px 20px;
    background: var(--color-surface);
  }
  .about-layout {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
  }
  .about-media {
    width: 100%;
  }
  .about-carousel {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }
  .about-track {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .about-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    opacity: 0;
    transform: scale(0.98);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .about-slide.active {
    opacity: 1;
    transform: scale(1);
  }
  .about-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--color-text-main);
  }
  .about-text {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }
  .about-stats {
    margin-top: 24px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    background: var(--color-surface-2);
    border-radius: 16px;
    padding: 24px;
  }
  .about-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
  }
  .about-stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.1;
  }
  .about-stat-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.3;
  }
  .about-cta {
    display: inline-block;
    margin-top: 18px;
    padding: 14px 24px;
    background: var(--color-accent);
    color: var(--color-on-accent);
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    text-align: center;
    min-height: 44px;
    min-width: 44px;
    transition: background 0.2s ease;
  }
  .about-cta:hover {
    background: var(--color-accent-hover);
  }
  @media (min-width: 640px) {
    .about-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .about-cta {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
  @media (min-width: 768px) {
    .about-section {
      padding: 80px 24px;
    }
    .about-layout {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
    .about-media {
      order: -1;
    }
    .about-content {
      order: 0;
    }
    .about-carousel {
      margin: 0;
      max-width: 100%;
    }
    .about-title {
      font-size: 2rem;
    }
    .about-text {
      font-size: 1.125rem;
    }
    .about-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .about-cta {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
  @media (max-width: 767px) {
    .about-content {
      order: -1;
    }
    .about-media {
      order: 0;
    }
  }
</style>
